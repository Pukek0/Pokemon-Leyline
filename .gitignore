# =========================================================
# Pokémon Studio / ROM Hack Project .gitignore
# =========================================================

# ---------------------------------------------------------
# Operating System Files
# ---------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------
# IDE / Editor Files
# ---------------------------------------------------------
.vscode/
.idea/
*.code-workspace

# Vim
*.swp
*.swo

# ---------------------------------------------------------
# Logs
# ---------------------------------------------------------
*.log
logs/

# ---------------------------------------------------------
# Temporary / Cache Files
# ---------------------------------------------------------
tmp/
temp/
.cache/
cache/

# Pokémon Studio cache/build folders
build/
dist/
exports/
export/
compiled/

# ---------------------------------------------------------
# Backup Files
# ---------------------------------------------------------
*.bak
*.backup
*.old
*.orig

# RPG Maker / Pokémon Studio autosaves
Autosave/
autosave/

# ---------------------------------------------------------
# Emulator Files
# ---------------------------------------------------------

# Save files
*.sav
*.sa1
*.sa2
*.state
*.sgm

# Emulator save states
*.sst
*.slot*

# Cheats
*.cht

# RTC
*.rtc

# ---------------------------------------------------------
# Generated ROMs / Patch Files
# ---------------------------------------------------------

# ROM outputs
*.gba
*.gbc
*.nds
*.cia
*.3ds
*.exe

# Patch files
*.ips
*.ups
*.bps
*.xdelta

# Archives
*.zip
*.7z
*.rar

# ---------------------------------------------------------
# Node / JS Plugin Tooling
# ---------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ---------------------------------------------------------
# Python Tooling
# ---------------------------------------------------------
__pycache__/
*.pyc

# ---------------------------------------------------------
# Image Editing Working Files
# ---------------------------------------------------------
*.psd
*.xcf
*.kra
*.clip

# ---------------------------------------------------------
# Audio Project Files
# ---------------------------------------------------------
*.flp
*.als
*.aup3

# ---------------------------------------------------------
# Video Editing Files
# ---------------------------------------------------------
*.prproj
*.veg
*.davinci

# ---------------------------------------------------------
# AI Upscale / Generated Assets
# ---------------------------------------------------------
upscaled/
generated/
renders/

# ---------------------------------------------------------
# Decompiled / Extracted ROM Files
# (Only ignore if you regenerate these automatically)
# ---------------------------------------------------------
decomp/
extract/

# ---------------------------------------------------------
# Sensitive / Local Config
# ---------------------------------------------------------
.env
.env.local
config.local.yml
settings.local.json

# =========================================================
# IMPORTANT:
# Keep these tracked:
#
# Data/
# Graphics/
# Audio/
# Maps/
# Scripts/
# Plugins/
# PBS/
# Text/
# docs/
#
# These are the actual source files for your project.
# =========================================================
